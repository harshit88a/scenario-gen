{
  "map": "Town04",

  "scenario": {
    "type": "cut_in",
    "description": "Adversary from right lane cuts in front of ego on highway"
  },

  "ego": {
    "blueprint": "vehicle.lincoln.mkz_2017",
    "spawn": {
      "mode": "random"
    },
    "behavior": {
      "type": "ttc_brake",
      "target_speed": 14.0,
      "brake_intensity": 1.0,
      "ttc_threshold": 3.0,
      "maneuver": "straight"
    },
    "sensors": [
      {
        "id": "front_camera",
        "type": "sensor.camera.rgb",
        "transform": { "x": 1.5, "y": 0.0, "z": 1.4 },
        "attributes": { "image_size_x": 1280, "image_size_y": 720, "fov": 90 }
      }
    ]
  },

  "adversaries": [
    {
      "id": "adv_cut_in",
      "type": "vehicle",
      "blueprint": "vehicle.audi.a2",
      "spawn": {
        "mode": "relative_to_ego",
        "direction": "front_right",
        "distance": 25,
        "lateral_offset": 3.5
      },
      "behavior": {
        "type": "cut_in",
        "target_speed": 16.0,
        "cut_in_distance": 18.0,
        "maneuver": "straight"
      }
    }
  ],

  "environment": {
    "weather": "CloudyNoon",
    "traffic_lights": "normal"
  },

  "display": {
    "enabled": true,
    "camera": "behind"
  },

  "termination": {
    "max_distance_from_start": 120,
    "max_duration_seconds": 60,
    "end_on_collision": true
  },

  "postconditions": [
    { "type": "no_collision" }
  ]
}
